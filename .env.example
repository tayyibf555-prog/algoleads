# Copy to .env and fill in real values.

PORT=4002

# Admin login (HTTP Basic Auth — browser prompt)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Stripe webhook signing secret (set in Stripe → Developers → Webhooks).
# When set, all incoming /api/webhooks/stripe requests must carry a
# valid stripe-signature header. Until set, signature is skipped
# (fine for local testing).
STRIPE_WEBHOOK_SECRET=

# Calendly webhook signing key (similar — left empty during testing).
CALENDLY_WEBHOOK_SECRET=

# CORS — comma-separated list of allowed origins for the public
# /api/leads endpoint. The marketing site's URL goes here.
# Use * to allow any (fine for local).
ALLOWED_ORIGINS=*

# How many days of lead data to retain. Anything older is auto-deleted
# on a daily sweep. 0 disables retention (keep everything forever).
LEAD_RETENTION_DAYS=0
