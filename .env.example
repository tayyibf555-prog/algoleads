# Copy to .env for local dev. On Vercel, set these as Project
# Environment Variables in the dashboard.

# Local server port (Vercel ignores this).
PORT=4002

# Admin login (HTTP Basic Auth — browser prompt)
ADMIN_USER=admin
ADMIN_PASS=changeme

# ─────────────────────────────────────────────────────────────
# Database — Turso (libSQL).
#
# Local dev (default):  file:db/algo-admin.db   (a SQLite file)
# Production (Vercel):  libsql://<your-db>.turso.io
#
# To create a hosted Turso DB:
#   1. brew install tursodatabase/tap/turso
#   2. turso auth signup
#   3. turso db create algoleads
#   4. turso db show algoleads --url
#   5. turso db tokens create algoleads
# ─────────────────────────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Stripe webhook signing secret (Stripe → Developers → Webhooks).
# When set, every /api/webhooks/stripe request must carry a valid
# stripe-signature header. Leave empty to skip verification.
STRIPE_WEBHOOK_SECRET=

# Calendly webhook signing key (similar — empty = skip verification).
CALENDLY_WEBHOOK_SECRET=

# CORS — comma-separated list of allowed origins for the public
# /api/leads endpoint. Use * to allow any (fine for dev, tighten
# for production to your marketing-site domain only).
ALLOWED_ORIGINS=*

# Auto-delete leads older than N days. 0 disables auto-deletion.
# Only enforced in local mode (Vercel functions are stateless).
LEAD_RETENTION_DAYS=0
